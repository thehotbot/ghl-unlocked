{
  "manifest_version": 3,
  "name": "GHL Unlocked — Token Grabber",
  "version": "1.0.0",
  "description": "Extract auth tokens from GoHighLevel for CLI and Claude access",
  "permissions": [
    "activeTab",
    "clipboardWrite",
    "webRequest"
  ],
  "host_permissions": [
    "*://*.leadconnectorhq.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
